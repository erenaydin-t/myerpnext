# Copy to `.env` next to docker-compose.yml and fill in real values.

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------

# GHCR image published by .github/workflows/docker-build.yml
GHCR_IMAGE=ghcr.io/erenaydin-t/myerpnext

# Pin to the exact ERPNext version (preferred) or use the rolling tag
# IMAGE_TAG=v16.18.0
IMAGE_TAG=v16-latest

SITE_NAME=erpnext.example.com

# CHANGE THESE BEFORE GOING TO PRODUCTION
DB_ROOT_PASSWORD=changeme
ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Resource limits
# ---------------------------------------------------------------------------
# Defaults below are sized for a 16 GB RAM / 4 vCPU host using the
# percentage allocation documented in README.md (#resource-sizing).
#
# For any other host size, regenerate them:
#
#   ./scripts/tune-resources.sh                       # auto-detect
#   ./scripts/tune-resources.sh 32 8                  # 32 GB / 8 vCPU
#   ./scripts/tune-resources.sh >> .env               # append to this file
#
# Hand-tuning a single value is fine — e.g. if your DMS OCR pipeline is
# heavy, raise QUEUE_LONG_MEM_LIMIT and lower another service to match.
# ---------------------------------------------------------------------------

# MariaDB (InnoDB buffer pool is the main consumer)
DB_MEM_LIMIT=4177m
DB_CPU_LIMIT=2.0

# Frappe backend — gunicorn web workers
BACKEND_MEM_LIMIT=2506m
BACKEND_CPU_LIMIT=2.0

# Long queue — DMS OCR, LibreOffice PDF conversion, heavy reports
QUEUE_LONG_MEM_LIMIT=3063m
QUEUE_LONG_CPU_LIMIT=2.0

# Short queue — interactive background jobs
QUEUE_SHORT_MEM_LIMIT=1114m
QUEUE_SHORT_CPU_LIMIT=1.0

# Scheduler — cron-like job emitter (lightweight)
SCHEDULER_MEM_LIMIT=557m
SCHEDULER_CPU_LIMIT=0.6

# Socketio websocket service (Node.js)
WEBSOCKET_MEM_LIMIT=557m
WEBSOCKET_CPU_LIMIT=0.6

# Internal nginx (static + proxy to backend/websocket)
FRONTEND_MEM_LIMIT=557m
FRONTEND_CPU_LIMIT=1.0

# Frappe doctype/document cache
REDIS_CACHE_MEM_LIMIT=696m
REDIS_CACHE_CPU_LIMIT=0.4

# RQ broker + socketio pubsub
REDIS_QUEUE_MEM_LIMIT=696m
REDIS_QUEUE_CPU_LIMIT=0.4
