# Copy to `.env` next to docker-compose.yml and fill in real values.

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------

# GHCR image published by .github/workflows/docker-build.yml
GHCR_IMAGE=ghcr.io/erenaydin-t/myerpnext

# Pin to the exact ERPNext version (preferred) or use the rolling tag
# IMAGE_TAG=v16.18.0
IMAGE_TAG=v16-latest

SITE_NAME=erpnext.example.com

# CHANGE THESE BEFORE GOING TO PRODUCTION
DB_ROOT_PASSWORD=changeme
ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Frontend port binding
# ---------------------------------------------------------------------------
# How the internal nginx (container port 8080) is published on the host.
# Format is a standard Docker ports mapping string.
#
#   Default (commented out)  -> 127.0.0.1:9090:8080
#       Loopback only. Use a host-side reverse proxy (Nginx/Caddy/Traefik)
#       to terminate TLS and forward to 127.0.0.1:9090. Safest default.
#
#   Behind a CDN/WAF that terminates TLS (no local TLS, public HTTP):
#       FRONTEND_PORT_BINDING=0.0.0.0:80:8080
#
# SECURITY: exposing the origin on a public port means anyone who hits the
# server IP directly reaches ERPNext over plain HTTP, bypassing the CDN/WAF.
# Lock the host firewall so port 80 only accepts your CDN's published IP
# ranges, or you lose the protection the CDN/WAF is meant to provide.
# FRONTEND_PORT_BINDING=0.0.0.0:80:8080

# ---------------------------------------------------------------------------
# DNS resolvers (container internet access)
# ---------------------------------------------------------------------------
# Every Frappe service is given explicit DNS resolvers so outbound name
# lookups work even when Docker's embedded DNS can't reach the host resolver
# (systemd-resolved / VPN / corporate DNS) — the usual cause of "ERPNext has
# no internet" (email, OAuth/Logto, webhooks, currency APIs).
# Defaults are Cloudflare + Google. Override only if your network blocks them
# or requires an internal resolver.
# DNS_PRIMARY=1.1.1.1
# DNS_SECONDARY=8.8.8.8

# ---------------------------------------------------------------------------
# Resource limits
# ---------------------------------------------------------------------------
# Intentionally NONE. No memory or CPU caps are applied to any service —
# each container may use the full host capacity. This prevents cgroup OOM
# kills (exit 137) during memory-heavy operations such as `bench build`.
# Size the HOST (RAM + swap) for your workload instead of capping containers.
# ---------------------------------------------------------------------------
